# Flask
SECRET_KEY=replace-with-a-long-random-secret
FLASK_DEBUG=false

# Frontend
FRONTEND_URL=http://127.0.0.1:5500
CORS_ALLOWED_ORIGINS=http://127.0.0.1:5500,http://localhost:5500,http://127.0.0.1:3000,http://localhost:3000
CORS_ALLOW_ALL=false

# MySQL
DB_HOST=localhost
DB_USER=root
DB_PASSWORD=replace-with-your-mysql-password
DB_NAME=doctor_booking_db

# Email / SMTP
MAIL_SERVER=smtp.gmail.com
MAIL_PORT=587
MAIL_USE_TLS=true
MAIL_USE_SSL=false
MAIL_USERNAME=your-email@example.com
MAIL_PASSWORD=replace-with-your-app-password
MAIL_DEFAULT_SENDER=your-email@example.com
MAIL_SENDER_NAME=Wisdom Hospital

# Twilio SMS
TWILIO_ACCOUNT_SID=
TWILIO_AUTH_TOKEN=
TWILIO_PHONE_NUMBER=
TWILIO_STATUS_CALLBACK_URL=
