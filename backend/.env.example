# ===================================================
# SECURITY CONFIGURATION
# ===================================================

# Replace with a long random secret in production
SECRET_KEY=replace_with_a_secure_random_secret


# ===================================================
# EMAIL (SMTP) CONFIGURATION FOR SENDING EMAILS
# ===================================================

# SMTP server used to send emails (Gmail SMTP service by default)
MAIL_SERVER=smtp.gmail.com

# Port used by the SMTP server (587 is the standard TLS port)
MAIL_PORT=587

# Enable TLS encryption for secure email transmission
MAIL_USE_TLS=true

# Disable SSL because TLS is used instead
MAIL_USE_SSL=false

# Email account used to send emails from the application
MAIL_USERNAME=your_email@example.com

# App password or SMTP password
MAIL_PASSWORD=replace_with_your_mail_password

# Default email address used as the sender
MAIL_DEFAULT_SENDER=your_email@example.com

# Name displayed as the sender in outgoing emails
MAIL_SENDER_NAME=Wisdom Hospital


# ===================================================
# TWILIO CONFIGURATION FOR SMS NOTIFICATIONS
# ===================================================

# Unique Twilio account identifier used to authenticate API requests
TWILIO_ACCOUNT_SID=replace_with_your_twilio_account_sid

# Twilio authentication token used to sign API requests
TWILIO_AUTH_TOKEN=replace_with_your_twilio_auth_token

# Twilio phone number used by the system to send SMS messages
TWILIO_PHONE_NUMBER=+10000000000

# Webhook URL where Twilio sends SMS delivery status updates
TWILIO_STATUS_CALLBACK_URL=https://your-public-url.example.com/webhooks/twilio/sms-status
